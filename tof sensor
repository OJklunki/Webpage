constexpr u8_t mA_pwm = /*write the pin*/;
constexpr u8_t mA_dir1 = /*write the pin*/;
constexpr u8_t mA_dir2 = /*write the pin*/;
constexpr u8_t mB_pwm = /*write the pin*/;
constexpr u8_t mB_dir1 = /*write the pin*/;
constexpr u8_t mB_dir2 = /*write the pin*/;

// dc driver
void init_L298N(){
  pinMode(mA_dir1, OUTPUT);
  pinMode(mA_dir2, OUTPUT);
  pinMode(mB_dir1, OUTPUT);
  pinMode(mB_dir2, OUTPUT);
  ledcSetup(0, 5000, 10);
  ledcAttachPin(mA_pwm, 0);
  ledcSetup(1, 5000, 10);
  ledcAttachPin(mB_pwm, 1);
}

u16_t pre_to_pwm(u8_t p){
  u16_t pwm = map(p, 0, 100, 0, 1024);
  return pwm;
}
 u8_t dirpins[] = {mA_dir1, mA_dir2, mB_dir1, mB_dir2};

void L298N(u8_t a, u8_t b, u8_t s, bool d){
  u8_t dir1 = dirpins[a];
  u8_t dir2 = dirpins[b];
  u8_t speed = s;
  bool direction = d;
  if (direction){
    digitalWrite(dir1, LOW);
    digitalWrite(dir2, HIGH);
  } else {
    digitalWrite(dir1, HIGH);
    digitalWrite(dir2, LOW);
  }
  if (a == 1) {
    ledcWrite(0, speed);
  } else{
    ledcWrite(1, speed);
  }
}

float fanspeed = 0;

void fanspeed_regulator(){
  if(averge_temperature() <= 10){
    fanspeed = 10;
  } else if(averge_temperature() > 10 && averge_temperature() <= 20){
    fanspeed = 25;
  } else if(averge_temperature() > 20 && averge_temperature() <= 22){
    fanspeed = 35;
  } else if(averge_temperature() > 22 && averge_temperature() <= 24){
    fanspeed = 50;
  } else if(averge_temperature() > 24 && averge_temperature() <= 26){
    fanspeed = 60;
  } else if (averge_temperature() > 26 && averge_temperature() <= 30){
    fanspeed = 80;
  } else {
    fanspeed = 100;
  }
}

void setup() {
  Serial.begin(115200);
  for (int i = 0; i < 3; i++){
    dht[i].begin();
  }
  delay(1000);
  init_L298N();
  // I2C first
  Wire.begin(TOF_A_SDA, TOF_A_SCL);
  Wire1.begin(TOF_B_SDA, TOF_B_SCL);

  // ESP-NOW
  WiFi.mode(WIFI_STA);
  if (esp_now_init() != ESP_OK) {
    Serial.println("Error initializing ESP-NOW");
    return;
  }

  esp_now_register_send_cb(OnDataSent);
  memcpy(peerInfo.peer_addr, broadcastAddress, 6);
  peerInfo.channel = 0;
  peerInfo.encrypt = false;
  if (esp_now_add_peer(&peerInfo) != ESP_OK) {
    Serial.println("Failed to add peer");
    return;
  }
  init_tofpins();
  init_tofA();
  init_tofB();
  Serial.println("Both sensors running!");
}

void loop() {
  readingTOF();
  // fan function
  L298N(1, 2,fanspeed, false);
  L298N(1, 2,fanspeed, false);

  // Send ESP-NOW
  if (millis() - previousmillis >= intervaltof) {
    previousmillis = millis();
    esp_err_t result = esp_now_send(broadcastAddress, (uint8_t *) &myData, sizeof(myData));
    if (result != ESP_OK) Serial.println("Send error");
  }
}
