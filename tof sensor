    } else {
    return averge_hum;
    myData.Humidity_avg = averge_hum;
    }
  }
}



// Pin Definitions for tof sensor
constexpr uint8_t TOF_A_SDA   = 21;
constexpr uint8_t TOF_A_SCL   = 22;
constexpr uint8_t TOF_A_XSHUT = 4;
constexpr uint8_t TOF_A_INT   = 17;

constexpr uint8_t TOF_B_SDA   = 33;
constexpr uint8_t TOF_B_SCL   = 32;
constexpr uint8_t TOF_B_XSHUT = 16;
constexpr uint8_t TOF_B_INT   = 5;

constexpr u8_t TOF_MEASURE_MS = 50;
constexpr u8_t PRINT_INTERVAL = 100;

VL53L1X sensorA;
VL53L1X sensorB;

volatile bool sensorA_DataReady = false;
volatile bool sensorB_DataReady = false;
uint16_t distA = 0;
uint16_t distB = 0;
unsigned long lastPrintTime = 0;

enum TofState { READ_A, READ_B };
TofState tofState = READ_A;

void IRAM_ATTR onSensorA_Ready() { sensorA_DataReady = true; }
void IRAM_ATTR onSensorB_Ready() { sensorB_DataReady = true; }

void readingTOF(){
  switch(tofState) {
    case READ_A:
      sensorB.stopContinuous();        
      sensorA.startContinuous(TOF_MEASURE_MS);
      if (sensorA_DataReady) {
        sensorA_DataReady = false;
        distA = sensorA.read(false);
        if (sensorA.timeoutOccurred()) Serial.println("[ERROR] Sensor A timeout");
        tofState = READ_B;
      }
      break;

    case READ_B:
      sensorA.stopContinuous();        
      sensorB.startContinuous(TOF_MEASURE_MS);
      if (sensorB_DataReady) {
        sensorB_DataReady = false;
        distB = sensorB.read(false);
        if (sensorB.timeoutOccurred()) Serial.println("[ERROR] Sensor B timeout");
        tofState = READ_A;
      }
      break;
  }


  unsigned long now = millis();
  if (now - lastPrintTime >= PRINT_INTERVAL) {
    lastPrintTime = now;
    if (distA < 8190) tempA += distA;
    if (distB < 8190) tempB += distB;
    counter++;

    Serial.print("Sensor A: ");
    Serial.print(distA);
    Serial.print(" mm | Sensor B: ");
    Serial.print(distB);
    Serial.println(" mm");

    if (millis() - previousaverage >= 500) {
      previousaverage = millis();
      if (counter > 0) {
        myData.DistanceA = tempA / counter;
        myData.DistanceB = tempB / counter;
      }
      tempA = 0;
      tempB = 0;
      counter = 0;
      myData.ObjectSize = 62 - myData.DistanceA - myData.DistanceB + 6;
      if (myData.ObjectSize <= 3) {
      myData.ObjectSize = 0;
      } else {
       Serial.println("Something wrong happend with os");
       Serial.println("");
       }
      
      Serial.print("Avg A: "); Serial.print(myData.DistanceA);
      Serial.print(" | Avg B: "); Serial.print(myData.DistanceB);
      Serial.print(" | Object: "); Serial.println(myData.ObjectSize);
    }
  }
}

void init_tofpins(){
  pinMode(TOF_A_XSHUT, OUTPUT);
  pinMode(TOF_B_XSHUT, OUTPUT);
  pinMode(TOF_A_INT, INPUT_PULLUP);
  pinMode(TOF_B_INT, INPUT_PULLUP);

  digitalWrite(TOF_A_XSHUT, LOW);
  digitalWrite(TOF_B_XSHUT, LOW);
  delay(10);
}

void init_tofA(){
  Serial.print("Sensor A... ");
  digitalWrite(TOF_A_XSHUT, HIGH);
  delay(50);
  sensorA.setBus(&Wire);
  if (!sensorA.init()) { Serial.println("FAILED!"); while(1); }
  sensorA.setDistanceMode(VL53L1X::Short);
  sensorA.setMeasurementTimingBudget(TOF_MEASURE_MS * 1000UL);
  sensorA.startContinuous(TOF_MEASURE_MS);
  attachInterrupt(digitalPinToInterrupt(TOF_A_INT), onSensorA_Ready, FALLING);
  Serial.println("Ready!");
}

void init_tofB(){
  Serial.print("Sensor B... ");
  digitalWrite(TOF_B_XSHUT, HIGH);
  delay(50);
  sensorB.setBus(&Wire1);
  if (!sensorB.init()) { Serial.println("FAILED!"); while(1); }
  sensorB.setDistanceMode(VL53L1X::Short);
  sensorB.setMeasurementTimingBudget(TOF_MEASURE_MS * 1000UL);
  sensorB.startContinuous(TOF_MEASURE_MS);
  attachInterrupt(digitalPinToInterrupt(TOF_B_INT), onSensorB_Ready, FALLING);
  Serial.println("Ready!");
}
