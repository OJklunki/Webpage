};


// function for temprature reading
void tempraturereading(u8_t id){
  if (millis() - previousdht[id] >= intervaltemp) {
    previousdht[id] = millis();
    humidity[id]    = dht[id].readHumidity();
    temperature[id] = dht[id].readTemperature();

    if (isnan(humidity[id]) || isnan(temperature[id])) {
    Serial.println("Failed to read from DHT11!");
    return;
    }
    Serial.print("Temperature form dht: ");
    Serial.print(temperature[id]);
    Serial.println(" C");

    Serial.print("Humidity: ");
    Serial.print(humidity[id]);
    Serial.println(" %");
  }
}

float averge_temperature(){
  if (millis() - previousaverge_temperature > 2000){
    previousaverge_temperature = millis();
    float averge_temp = (temperature[0] + temperature[1] + temperature[2]) /3;
    if(averge_temp <= 8 || averge_temp >= 100){
      return -1;
      Serial.println("Something wrong happend with the function averge_temperature");
    } else {
    return averge_temp;
    myData.Temperature_avg = averge_temp;
    }
  }
}

float averge_humidity(){
  if(millis() - previousaverge_humidity > 2000){
    previousaverge_humidity = millis();
    float averge_hum = (humidity[0] + humidity[1] + humidity[2]) /3;
    if(averge_hum <= 8 || averge_hum >= 100){
