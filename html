// ─── VISUALS ───────────────────────────────────────────────────────────────
function updateVisuals(joint, value) {
  value = parseInt(value);
  const sliders = document.querySelectorAll('input[type=range]');

  if      (joint === 0) { document.getElementById("val0").innerText = value + "\xB0"; rootPivot.rotation.y    = (value-90)*Math.PI/180; sliders[0].value = value; }
  else if (joint === 1) { document.getElementById("val1").innerText = value + "\xB0"; tilt1Pivot.rotation.x   = (value-90)*Math.PI/180; sliders[1].value = value; }
  else if (joint === 2) { document.getElementById("val2").innerText = value + "\xB0"; tilt2Pivot.rotation.x   = (value-90)*Math.PI/180; sliders[2].value = value; }
  else if (joint === 3) { document.getElementById("val3").innerText = value + "\xB0"; tilt3Pivot.rotation.x   = (value-90)*Math.PI/180; sliders[3].value = value; }
  else if (joint === 4) { document.getElementById("val4").innerText = value + "\xB0"; gripperPivot.rotation.y = (value-90)*Math.PI/180; sliders[4].value = value; }
  else if (joint === 5) {
    document.getElementById("val5").innerText = value + " mm";
    gripperLeft.position.x  = -(0.8 + value / 26.96);
    gripperRight.position.x =  (0.8 + value / 26.96);
    sliders[5].value = value;
  }
}

// ─── INVERSE KINEMATICS ────────────────────────────────────────────────────
// Physical constants — MUST match the values in Robot_main.cpp
const IK = {
  L1: 80, L2: 100, L3: 200, BASE_H: 130,
  MIN_R:  100,            // minimum reach (mm)
  // Calibration (mirrors firmware constants):
  T1_OFFSET: 90, T1_SIGN:  1,
  T2_OFFSET: 90, T2_SIGN:  1,
  T3_OFFSET: 90, T3_SIGN:  1
};

// Returns {t1, t2, t3} servo values (0-180) or null if unreachable.
function solveIK(reach_mm, tip_height_mm) {
  reach_mm = Math.max(reach_mm, IK.MIN_R);

  // Wrist pivot target (wrist pointing straight down)
  let Rw = reach_mm;
  let Hw = (tip_height_mm - IK.BASE_H) + IK.L3;   // e.g. tip at 0mm → Hw = 70

  let d2 = Rw*Rw + Hw*Hw;
  let d  = Math.sqrt(d2);

  const maxR = IK.L1 + IK.L2 - 1;
  const minR = Math.abs(IK.L1 - IK.L2) + 1;

  if (d < minR) return null;            // target too close (shouldn't happen with reach≥100)

  if (d > maxR) {                       // clamp to max reach
    const s = maxR / d;
    Rw *= s;  Hw *= s;
    d2 = Rw*Rw + Hw*Hw;
    d  = Math.sqrt(d2);
  }

  // Law of cosines
  let cosA2 = (IK.L1**2 + IK.L2**2 - d2) / (2 * IK.L1 * IK.L2);
  cosA2 = Math.max(-1, Math.min(1, cosA2));
  const A2 = Math.acos(cosA2);                 // bend angle at tilt2

  const alpha = Math.atan2(Hw, Rw);            // elevation of wrist target from tilt1
  let cosB = (IK.L1**2 + d2 - IK.L2**2) / (2 * IK.L1 * d);
  cosB = Math.max(-1, Math.min(1, cosB));
  const beta = Math.acos(cosB);

  const theta1     = alpha + beta;             // lower arm angle from horizontal (elbow-up)
  const thetaUp    = theta1 - Math.PI + A2;    // upper arm angle from horizontal
  const theta3corr = -Math.PI/2 - thetaUp;     // tilt3 correction to keep wrist down

  const t1_deg = theta1     * 180 / Math.PI;
  const A2_deg = A2         * 180 / Math.PI;
  const t3_deg = theta3corr * 180 / Math.PI;

  return {
    t1: Math.round(Math.max(0, Math.min(180, IK.T1_OFFSET + IK.T1_SIGN * (t1_deg - 90)))),
    t2: Math.round(Math.max(0, Math.min(180, IK.T2_OFFSET + IK.T2_SIGN * A2_deg))),
    t3: Math.round(Math.max(0, Math.min(180, IK.T3_OFFSET + IK.T3_SIGN * t3_deg)))
  };
}

// Smoothly animate a joint to a target servo value over `duration` ms
function animateJoint(joint, targetVal, duration) {
  const sliders  = document.querySelectorAll('input[type=range]');
  const startVal = parseInt(sliders[joint].value);
  const t0       = performance.now();

  function step(now) {
    const frac = Math.min(1, (now - t0) / duration);
    // ease-in-out quad
    const ease = frac < 0.5 ? 2*frac*frac : 1 - Math.pow(-2*frac+2, 2)/2;
    updateVisuals(joint, Math.round(startVal + (targetVal - startVal) * ease));
    if (frac < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

// Called by the LOWER ARM button
function triggerLowerArm() {
  const reach  = parseInt(document.getElementById('ikReach').value);
  const height = parseInt(document.getElementById('ikHeight').value);
  const ik     = solveIK(reach, height);

  const btn    = document.getElementById('lowerBtn');
  const status = document.getElementById('ikStatus');

  if (!ik) {
    status.style.color = '#ff5555';
    status.innerText = 'UNREACHABLE — try less reach or more height';
    return;
  }

  status.style.color = 'rgba(0,255,100,0.6)';
  status.innerText = `\u2192 T1:${ik.t1}\xB0  T2:${ik.t2}\xB0  T3:${ik.t3}\xB0`;

  // Animate 3D preview
  const DURATION = 900; // ms
  animateJoint(1, ik.t1, DURATION);
  animateJoint(2, ik.t2, DURATION);
  animateJoint(3, ik.t3, DURATION);

  // Visual feedback on button
  btn.classList.add('running');
  btn.innerText = '\u23F3  MOVING\u2026';
  setTimeout(() => {
    btn.classList.remove('running');
    btn.innerHTML = '\u2713&nbsp; DONE';
    setTimeout(() => { btn.innerHTML = '\u2681&nbsp; LOWER ARM'; }, 1200);
  }, DURATION + 200);

  // Send to firmware via WebSocket
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({ cmd: 'lower_arm', reach, height }));
  }
}

// ─── WEBSOCKET ─────────────────────────────────────────────────────────────
let ws;
const statusDot  = document.getElementById('statusDot');
const statusText = document.getElementById('statusText');

function connectWS() {
  ws = new WebSocket('ws://' + location.hostname + '/ws');

  ws.onopen = () => {
    statusDot.classList.remove('disconnected');
    statusText.textContent = 'CONNECTED \u2014 ESP32 ROBOT ARM';
  };

  ws.onclose = () => {
    statusDot.classList.add('disconnected');
    statusText.textContent = 'DISCONNECTED \u2014 retrying...';
    setTimeout(connectWS, 2000);
  };

  ws.onerror = () => ws.close();

  ws.onmessage = (event) => {
    try {
      const data = JSON.parse(event.data);
      if (data.type === 'positions') {
        if (data.base    !== undefined) updateVisuals(0, data.base);
        if (data.tilt1   !== undefined) updateVisuals(1, data.tilt1);
        if (data.tilt2   !== undefined) updateVisuals(2, data.tilt2);
        if (data.tilt3   !== undefined) updateVisuals(3, data.tilt3);
        if (data.twist   !== undefined) updateVisuals(4, data.twist);
        if (data.gripper !== undefined) updateVisuals(5, data.gripper);
      }
    } catch(e) {
      console.warn('Bad message from ESP32:', event.data);
    }
  };
}

connectWS();

function updateJoint(joint, value) {
  updateVisuals(joint, value);
  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({ joint: joint, value: parseInt(value) }));
  }
}

// ─── RENDER LOOP ───────────────────────────────────────────────────────────
function animate() {
  requestAnimationFrame(animate);
  renderer.render(scene, camera);
}
animate();

</script>
