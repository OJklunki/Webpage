<script>

// ─── SCENE SETUP ───────────────────────────────────────────────────────────
const canvas = document.getElementById('c');
const container = document.getElementById('canvas-container');
container.style.width  = '420px';
container.style.height = '500px';
canvas.width  = 420;
canvas.height = 500;

const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setSize(420, 500);
renderer.shadowMap.enabled = true;
renderer.setPixelRatio(window.devicePixelRatio);

const scene  = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(45, 420/500, 0.1, 1000);
camera.position.set(0, 25, 60);
camera.lookAt(0, 15, 0);

const ambient = new THREE.AmbientLight(0x003322, 2);
scene.add(ambient);
const dirLight = new THREE.DirectionalLight(0x00ffcc, 1.5);
dirLight.position.set(20, 40, 20);
scene.add(dirLight);
const dirLight2 = new THREE.DirectionalLight(0x0044ff, 0.8);
dirLight2.position.set(-20, 10, -10);
scene.add(dirLight2);

const gridHelper = new THREE.GridHelper(650, 200, 0x003322, 0x001a11);
scene.add(gridHelper);

const matBase    = new THREE.MeshPhongMaterial({ color: 0x0d3d3d, emissive: 0x001a1a, shininess: 80 });
const matTeal    = new THREE.MeshPhongMaterial({ color: 0x0a4a4a, emissive: 0x002222, shininess: 80 });
const matGripper = new THREE.MeshPhongMaterial({ color: 0x0d3d3d, emissive: 0x001a1a, shininess: 80 });

function addWireframe(mesh, color) {
  const geo = new THREE.WireframeGeometry(mesh.geometry);
  const mat = new THREE.LineBasicMaterial({ color, opacity: 0.15, transparent: true });
  mesh.add(new THREE.LineSegments(geo, mat));
}

function makeBox(w, h, d, mat) {
  const mesh = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), mat || matBase);
  addWireframe(mesh, 0x00ffcc);
  return mesh;
}

function makeCyl(rt, rb, h, mat) {
  const mesh = new THREE.Mesh(new THREE.CylinderGeometry(rt, rb, h, 16), mat);
  addWireframe(mesh, 0x00ffcc);
  return mesh;
}

// ─── BUILD ARM ─────────────────────────────────────────────────────────────
const rootPivot = new THREE.Group();
scene.add(rootPivot);

const baseBox = makeBox(6, 7.9, 6, matBase);
baseBox.position.y = 7.9 / 2;
rootPivot.add(baseBox);

const tilt1Pivot = new THREE.Group();
tilt1Pivot.position.y = 6;
rootPivot.add(tilt1Pivot);

const baseJoint = makeBox(2, 8, 2, matBase);
baseJoint.position.set(4, 2.5, 0);
tilt1Pivot.add(baseJoint);

const singleArm = makeBox(6, 8, 6, matTeal);
singleArm.position.y = 8;
tilt1Pivot.add(singleArm);

const tilt2Pivot = new THREE.Group();
tilt2Pivot.position.y = 10;
tilt1Pivot.add(tilt2Pivot);

const tiltshaft1 = makeBox(2, 8, 2, matTeal);
tiltshaft1.position.set(4, 3.5, 0);
tilt2Pivot.add(tiltshaft1);

const tiltshaft2 = makeBox(2, 8, 2, matTeal);
tiltshaft2.position.set(-4, 3.5, 0);
tilt2Pivot.add(tiltshaft2);

const Gripperroation = makeBox(6, 5, 6, matTeal);
Gripperroation.position.set(0, 8, 0);
tilt2Pivot.add(Gripperroation);

const gripperPivot = new THREE.Group();
gripperPivot.position.y = 10.5;
tilt2Pivot.add(gripperPivot);

const twistBody = makeBox(6, 4, 6, matTeal);
twistBody.position.y = 2;
gripperPivot.add(twistBody);

const gripperBody = makeBox(10.2, 3, 4, matBase);
gripperBody.position.y = 5;
gripperPivot.add(gripperBody);

const gripperLeft = new THREE.Group();
gripperLeft.position.set(-0.8, 6, 0);
gripperPivot.add(gripperLeft);

const leftFinger = makeBox(1.5, 6.3, 3, matGripper);
leftFinger.position.y = 6.3 / 2;
gripperLeft.add(leftFinger);

const gripperRight = new THREE.Group();
gripperRight.position.set(0.8, 6, 0);
gripperPivot.add(gripperRight);

const rightFinger = makeBox(1.5, 6.3, 3, matGripper);
rightFinger.position.y = 6.3 / 2;
gripperRight.add(rightFinger);

[gripperLeft, gripperRight].forEach(g => {
  const edges = new THREE.EdgesGeometry(g.children[0].geometry);
  const line  = new THREE.LineSegments(edges, new THREE.LineBasicMaterial({ color: 0x00ff88 }));
  line.position.y = 6.3 / 2;
  g.add(line);
});

// ─── ORBIT ─────────────────────────────────────────────────────────────────
let isDragging = false;
let prevMouse  = { x: 0, y: 0 };
let spherical  = { theta: 0.3, phi: 1.1, radius: 60 };
let lastPinchDist = null;

function updateCamera() {
  camera.position.x = spherical.radius * Math.sin(spherical.phi) * Math.sin(spherical.theta);
  camera.position.y = spherical.radius * Math.cos(spherical.phi) + 15;
  camera.position.z = spherical.radius * Math.sin(spherical.phi) * Math.cos(spherical.theta);
  camera.lookAt(0, 15, 0);
}

canvas.addEventListener('mousedown', e => { isDragging = true; prevMouse = { x: e.clientX, y: e.clientY }; });
window.addEventListener('mouseup',   () => { isDragging = false; });
window.addEventListener('mousemove', e => {
  if (!isDragging) return;
  spherical.theta -= (e.clientX - prevMouse.x) * 0.01;
  spherical.phi    = Math.max(0.2, Math.min(Math.PI / 2, spherical.phi + (e.clientY - prevMouse.y) * 0.01));
  prevMouse = { x: e.clientX, y: e.clientY };
  updateCamera();
});
canvas.addEventListener('wheel', e => {
  e.preventDefault();
  spherical.radius = Math.max(10, Math.min(200, spherical.radius + e.deltaY * 0.1));
  updateCamera();
}, { passive: false });
canvas.addEventListener('touchstart', e => {
  if (e.touches.length === 1) { isDragging = true; prevMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY }; }
  if (e.touches.length === 2) lastPinchDist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
}, { passive: true });
window.addEventListener('touchend', e => { if (e.touches.length === 0) isDragging = false; if (e.touches.length < 2) lastPinchDist = null; });
window.addEventListener('touchmove', e => {
  if (e.touches.length === 1 && isDragging) {
    spherical.theta -= (e.touches[0].clientX - prevMouse.x) * 0.01;
    spherical.phi    = Math.max(0.2, Math.min(Math.PI / 2, spherical.phi + (e.touches[0].clientY - prevMouse.y) * 0.01));
    prevMouse = { x: e.touches[0].clientX, y: e.touches[0].clientY };
    updateCamera();
  }
  if (e.touches.length === 2 && lastPinchDist !== null) {
    const dist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
    spherical.radius = Math.max(10, Math.min(200, spherical.radius - (dist - lastPinchDist) * 0.2));
    lastPinchDist = dist;
    updateCamera();
  }
}, { passive: true });

// ─── VISUALS ───────────────────────────────────────────────────────────────
function updateVisuals(joint, value) {
  value = parseInt(value);
  const deg = value * Math.PI / 180;
  const sliders = document.querySelectorAll('input[type=range]');

  if      (joint === 0) { document.getElementById("val0").innerText = value + "°"; rootPivot.rotation.y   = deg; sliders[0].value = value; }
  else if (joint === 1) { document.getElementById("val1").innerText = value + "°"; tilt1Pivot.rotation.x  = deg; sliders[1].value = value; }
  else if (joint === 2) { document.getElementById("val2").innerText = value + "°"; tilt2Pivot.rotation.x  = deg; sliders[2].value = value; }
  else if (joint === 3) { document.getElementById("val3").innerText = value + "°"; gripperPivot.rotation.y = deg; sliders[3].value = value; }
  else if (joint === 4) {
    document.getElementById("val4").innerText = value + " mm";
    gripperLeft.position.x  = -(0.8 + value / 26.96);
    gripperRight.position.x =  (0.8 + value / 26.96);
    sliders[4].value = value;
  }
}

// ─── WEBSOCKET ─────────────────────────────────────────────────────────────
// One persistent connection replaces all fetch() calls and the polling interval.
// - Sending: slider moves → ws.send(JSON)
// - Receiving: ESP32 pushes position updates → updateVisuals()

let ws;
const statusDot  = document.getElementById('statusDot');
const statusText = document.getElementById('statusText');

function connectWS() {
  // Use the same host the page was served from so it works on both AP and home wifi
  ws = new WebSocket('ws://' + location.hostname + '/ws');

  ws.onopen = () => {
    statusDot.classList.remove('disconnected');
    statusText.textContent = 'CONNECTED — ESP32 ROBOT ARM';
    console.log('WebSocket connected');
  };

  ws.onclose = () => {
    statusDot.classList.add('disconnected');
    statusText.textContent = 'DISCONNECTED — retrying...';
    console.log('WebSocket closed, reconnecting in 2s');
    // Auto-reconnect after 2 seconds
    setTimeout(connectWS, 2000);
  };

  ws.onerror = (e) => {
    console.error('WebSocket error', e);
    ws.close(); // triggers onclose → reconnect
  };

  ws.onmessage = (event) => {
    // ESP32 pushes: {"type":"positions","base":0,"tilt1":0,"tilt2":0,"twist":0,"gripper":0}
    try {
      const data = JSON.parse(event.data);
      if (data.type === 'positions') {
        if (data.base    !== undefined) updateVisuals(0, data.base);
        if (data.tilt1   !== undefined) updateVisuals(1, data.tilt1);
        if (data.tilt2   !== undefined) updateVisuals(2, data.tilt2);
        if (data.twist   !== undefined) updateVisuals(3, data.twist);
        if (data.gripper !== undefined) updateVisuals(4, data.gripper);
      }
    } catch(e) {
      console.warn('Bad message from ESP32:', event.data);
    }
  };
}

connectWS();

// ─── SEND COMMAND ──────────────────────────────────────────────────────────
// Called by slider oninput — updates visuals locally for instant feedback,
// then sends the command over WebSocket
function updateJoint(joint, value) {
  updateVisuals(joint, value); // instant local feedback, no waiting for round-trip

  if (ws && ws.readyState === WebSocket.OPEN) {
    ws.send(JSON.stringify({ joint: joint, value: parseInt(value) }));
  }
}

// ─── RENDER LOOP ───────────────────────────────────────────────────────────
function animate() {
  requestAnimationFrame(animate);
  renderer.render(scene, camera);
}
animate();

</script>
</body>
