// angle to pulse
int angleToPulse(int angle) {
  angle = constrain(angle, 0, 180);
  return map(angle, 0, 180, 150, 550);
}

// myservo smooth
 void servosmooth(u8_t angle){
    u8_t angle = angle;
    if (angle == gripperCurrent){
      return;
    } else if(angle > gripperCurrent){
      if (millis()- previousservowrite >= SERVO_DELAY){
      previousservowrite = millis();
      gripperCurrent++;
      gripper.write(angleToPulse(gripperCurrent));
    }
    } else {
      if (millis()- previousservowrite >= SERVO_DELAY){
        previousservowrite = millis();
        gripperCurrent--;
        gripper.write(angleToPulse(gripperCurrent));
    }
  }
}

// busservo read
float Readposition(HardwareSerial &serial, u8_t id) {
    uint8_t lenght = 3;
    uint8_t cmd = 0x1C;


    uint8_t checksum = ~(lenght + cmd + posLow + posHigh + timeLow + timeHigh) & 0xFF;

    serial.write(0x55);
    serial.write(0x55);
    serial.write(id);
    serial.write(lenght);
    serial.write(checksum);
}

// busservo write
void Busservowrite(HardwareSerial &serial, uint8_t id, uint16_t position, uint16_t time_ms) {
    uint8_t len = 7;
    uint8_t cmd = 0x01;

    uint8_t posLow  = position & 0xFF;
    uint8_t posHigh = (position >> 8) & 0xFF;
    uint8_t timeLow  = time_ms & 0xFF;
    uint8_t timeHigh = (time_ms >> 8) & 0xFF;

    uint8_t checksum = ~(id + len + cmd + posLow + posHigh + timeLow + timeHigh) & 0xFF;

    serial.write(0x55);
    serial.write(0x55);
    serial.write(id);
    serial.write(len);
    serial.write(cmd);
    serial.write(posLow);
    serial.write(posHigh);
    serial.write(timeLow);
    serial.write(timeHigh);
    serial.write(checksum);
}

